{
  "_meta": {
    "source": "Pathfinder 2e Remaster GM Core, pages 94-95 (Climate, Precipitation, Temperature, Wind)",
    "notes": "Canonical PF2e weather rules. Damage values use the GM Core 'Tier' damage scale (Minor/Moderate/Major/Massive) — see the 'damageTiers' block. Climate tables are weighted probabilities for daily rolls.",
    "version": 1
  },

  "damageTiers": {
    "minor": { "dice": "1d6", "label": "Minor" },
    "moderate": { "dice": "4d6", "label": "Moderate" },
    "major": { "dice": "10d6", "label": "Major" },
    "massive": { "dice": "20d6", "label": "Massive" }
  },

  "temperature": {
    "incredibleCold":   { "label": "Incredible cold",  "rangeF": [-999, -80], "fatigueHours": 2, "damage": { "tier": "moderate", "type": "cold", "interval": "minute" }, "penalty": -4, "emoji": "🥶" },
    "extremeCold":      { "label": "Extreme cold",     "rangeF": [-79, -20],  "fatigueHours": 4, "damage": { "tier": "minor", "type": "cold", "interval": "10 minutes" }, "penalty": -3, "emoji": "❄️" },
    "severeCold":       { "label": "Severe cold",      "rangeF": [-21, 12],   "fatigueHours": 4, "damage": { "tier": "minor", "type": "cold", "interval": "hour" }, "penalty": -2, "emoji": "🧊" },
    "mildCold":         { "label": "Mild cold",        "rangeF": [13, 32],    "fatigueHours": 4, "damage": null, "penalty": -1, "emoji": "🌨️" },
    "normal":           { "label": "Normal",           "rangeF": [33, 94],    "fatigueHours": 8, "damage": null, "penalty": 0, "emoji": "🌤️" },
    "mildHeat":         { "label": "Mild heat",        "rangeF": [95, 104],   "fatigueHours": 4, "damage": null, "penalty": -1, "emoji": "☀️" },
    "severeHeat":       { "label": "Severe heat",      "rangeF": [105, 114],  "fatigueHours": 4, "damage": { "tier": "minor", "type": "fire", "interval": "hour" }, "penalty": -2, "emoji": "🔥" },
    "extremeHeat":      { "label": "Extreme heat",     "rangeF": [115, 139],  "fatigueHours": 4, "damage": { "tier": "minor", "type": "fire", "interval": "10 minutes" }, "penalty": -3, "emoji": "🌞" },
    "incredibleHeat":   { "label": "Incredible heat",  "rangeF": [140, 999],  "fatigueHours": 2, "damage": { "tier": "moderate", "type": "fire", "interval": "minute" }, "penalty": -4, "emoji": "🥵" }
  },

  "precipitation": {
    "none":          { "label": "Clear",          "fatigue": false, "soaked": false, "extinguishesFlames": false, "frozenAccumulation": false, "emoji": "☀️" },
    "drizzle":       { "label": "Drizzle",        "fatigue": false, "soaked": false, "extinguishesFlames": "tiny", "frozenAccumulation": false, "emoji": "🌦️", "perceptionPenalty": -1 },
    "lightSnow":     { "label": "Light snow",     "fatigue": false, "soaked": false, "extinguishesFlames": "tiny", "frozenAccumulation": true, "emoji": "🌨️", "perceptionPenalty": -1 },
    "rain":          { "label": "Rain",           "fatigue": "4h", "soaked": true, "extinguishesFlames": "unprotected", "frozenAccumulation": false, "emoji": "🌧️", "perceptionPenalty": -2 },
    "snow":          { "label": "Snow",           "fatigue": "4h", "soaked": false, "extinguishesFlames": "unprotected", "frozenAccumulation": true, "emoji": "❄️", "perceptionPenalty": -2 },
    "sleet":         { "label": "Sleet",          "fatigue": "4h", "soaked": true, "extinguishesFlames": "unprotected", "frozenAccumulation": true, "emoji": "🌨️", "perceptionPenalty": -2 },
    "heavyRain":     { "label": "Heavy rain",     "fatigue": "4h", "soaked": true, "extinguishesFlames": "any", "frozenAccumulation": false, "emoji": "⛈️", "perceptionPenalty": -3 },
    "blizzard":      { "label": "Blizzard",       "fatigue": "4h", "soaked": false, "extinguishesFlames": "any", "frozenAccumulation": true, "emoji": "🌬️❄️", "perceptionPenalty": -4, "note": "Combines cold weather, heavy snow, and strong winds." },
    "thunderstorm":  { "label": "Thunderstorm",   "fatigue": "4h", "soaked": true, "extinguishesFlames": "any", "frozenAccumulation": false, "emoji": "⛈️", "perceptionPenalty": -3, "lightning": { "tier": "moderate", "type": "electricity", "chancePerHour": 0.005 } },
    "severeThunderstorm": { "label": "Severe thunderstorm", "fatigue": "4h", "soaked": true, "extinguishesFlames": "any", "frozenAccumulation": false, "emoji": "🌩️", "perceptionPenalty": -4, "lightning": { "tier": "major", "type": "electricity", "chancePerHour": 0.01 } },
    "hail":          { "label": "Hail",           "fatigue": "4h", "soaked": false, "extinguishesFlames": "any", "frozenAccumulation": false, "emoji": "🌧️", "perceptionPenalty": -2 }
  },

  "wind": {
    "calm":      { "label": "Calm",          "auditoryPenalty": 0,  "rangedPenalty": 0, "rangedImpossible": false, "extinguishes": "none",     "emoji": "🍃" },
    "light":     { "label": "Light wind",    "auditoryPenalty": 0,  "rangedPenalty": 0, "rangedImpossible": false, "extinguishes": "none",     "emoji": "🍃" },
    "moderate":  { "label": "Moderate wind", "auditoryPenalty": -1, "rangedPenalty": -1, "rangedImpossible": false, "extinguishes": "tiny",     "emoji": "💨" },
    "strong":    { "label": "Strong wind",   "auditoryPenalty": -2, "rangedPenalty": -2, "rangedImpossible": false, "extinguishes": "handheld", "emoji": "💨", "note": "Difficult terrain when flying." },
    "severe":    { "label": "Severe wind",   "auditoryPenalty": -3, "rangedPenalty": -4, "rangedImpossible": false, "extinguishes": "lanterns", "emoji": "🌬️", "note": "Greater difficult terrain when flying. Athletics check to move on the ground for Small/Tiny creatures." },
    "windstorm": { "label": "Windstorm",     "auditoryPenalty": -4, "rangedPenalty": -4, "rangedImpossible": true,  "extinguishes": "all",      "emoji": "🌪️", "note": "Ranged attacks impossible. Athletics check to move; fliers can be blown away on a critical failure." }
  },

  "fog": {
    "none":  { "label": "Clear",         "perceptionPenalty": 0, "concealment": false, "visibility": "normal", "emoji": "" },
    "haze":  { "label": "Haze",          "perceptionPenalty": -1, "concealment": false, "visibility": "3 miles", "emoji": "🌫️" },
    "mist":  { "label": "Mist",          "perceptionPenalty": -2, "concealment": false, "visibility": "1 mile",  "emoji": "🌫️" },
    "fog":   { "label": "Fog",           "perceptionPenalty": -3, "concealment": true,  "visibility": "half mile", "emoji": "🌫️" },
    "heavyFog": { "label": "Heavy fog",  "perceptionPenalty": -4, "concealment": true,  "visibility": "5-30 feet", "emoji": "🌁", "note": "Concealment to all creatures; visibility cut to as little as 5 feet." }
  },

