# Copy to `bot.env` and fill in. bot.env is git-ignored — never commit secrets.
# These map 1:1 to the vars the bot read on Railway.

# --- Discord ---
DISCORD_TOKEN=            # bot token (Developer Portal → Bot → Reset Token)
CLIENT_ID=               # application (client) ID
BOT_OWNER_ID=            # your Discord user ID (admin cmds + feedback DM fallback)

# --- Supabase (same project the web app + bot already use) ---
SUPABASE_URL=            # https://<project>.supabase.co
SUPABASE_SERVICE_KEY=    # service_role key (bypasses RLS — keep secret)

# --- Optional ---
FEEDBACK_CHANNEL_ID=     # channel for website Contact submissions; blank = DM the owner
DEV_GUILD_ID=            # guild for instant slash-command testing (npm run deploy:guild)
