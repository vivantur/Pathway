# Pathway website — environment configuration
#
# Copy this file to ".env" and fill in the values from your Supabase project.
# The ".env" file is git-ignored, so your keys are never committed.
#
# IMPORTANT: use the ANON / PUBLISHABLE key only — NEVER the service-role key.
# The website acts as the logged-in user and relies on RLS for security.
# (The service-role key bypasses all security and must stay server-side only.)
#
# Default to the DEVELOP project for day-to-day work, not production.
#   develop project ref: nqnswvuqszpkntnjzomv
#   prod project ref:    cmmwirlrvqmjqbydlqks   (deploy only)

VITE_SUPABASE_URL=https://nqnswvuqszpkntnjzomv.supabase.co
VITE_SUPABASE_ANON_KEY=your-develop-anon-key-here
