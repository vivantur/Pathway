# Copy this file to .env and fill in your values.
# Never commit .env — it contains your secret bot token.

# Your bot's token from https://discord.com/developers/applications → Bot → Token
TOKEN=your-discord-bot-token-here

# Your application's client ID from https://discord.com/developers/applications → General Information
CLIENT_ID=your-application-client-id-here

# (Optional) Your Discord user ID — used to grant bot-owner commands
BOT_OWNER_ID=your-discord-user-id-here

# (Optional) A server (guild) ID for instant slash-command testing.
# Commands deployed to a specific guild update in seconds instead of ~1 hour.
# Leave blank (or remove the line) to deploy globally.
DEV_GUILD_ID=your-dev-server-id-here

# (Optional) Override where data files are stored (defaults to project root).
# Useful when running the bot on a server with a separate data volume.
# DATA_DIR=/app/data

# (Optional) Supabase integration — enables the web app combat tracker and
# character sheet viewer. Leave blank to run the bot without web sync.
# Get these from your Supabase project: Settings → API
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
