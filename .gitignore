# Raw AoN dumps - regenerate with `node apps/bot/tools/aon-fetch.js`
apps/bot/gamedata/aon-raw/*.json
!apps/bot/gamedata/aon-raw/README.md
!apps/bot/gamedata/aon-raw/.gitkeep

# Reference JSON files - archived in git tag `gamedata-archive-20260506`.
# All reference data now lives in the Supabase `gamedata` / `monsters` / `spells`
# / `items` tables and is loaded at startup by loadReferenceDatabasesFromSupabase().
# These files are kept on disk for the AoN transformer tools
# (apps/bot/tools/aon-*.js) but must never be committed - the bot no longer
# reads them at runtime.
apps/bot/gamedata/*.json

# Local backups - don't push these
apps/bot/gamedata/*.backup
*.backup
characters.json
saves/*.json

# Build output. packages/core/dist is GENERATED from packages/core/src by
# `npm run build` (wired to `prepare`, so any install produces it). Never commit
# it: a stale committed dist would let the bot compute with old rules while the
# web app reads fresh source — exactly the drift packages/core exists to prevent.
packages/core/dist/

# The usual suspects
node_modules/
.env
.claude/

# Bot hosting secrets (Docker env file — never commit)
bot.env
